{
  "name": "react-example",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "setup": "chmod +x setup.sh && ./setup.sh",
    "postinstall": "npm run setup",
    "dev": "npx tsx watch --expose-gc server.ts",
    "start": "node --expose-gc dist/server.cjs",
    "build": "vite build && npx esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "desktop": "electron electron/main.cjs",
    "dist:win": "electron-builder --win"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.papercreeper.ai",
    "productName": "PaperCreeper AI",
    "directories": {
      "output": "dist-desktop"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "lucide-react": "^0.546.0",
    "minecraft-data": "^3.110.0",
    "mineflayer": "^4.37.1",
    "mineflayer-pathfinder": "^2.4.5",
    "motion": "^12.23.24",
    "mssql": "^12.5.2",
    "multer": "^2.1.1",
    "prismarine-block": "^1.23.0",
    "prismarine-chunk": "^1.40.0",
    "prismarine-nbt": "^2.8.0",
    "prismarine-provider-anvil": "^2.13.0",
    "prismarine-registry": "^1.12.0",
    "prismarine-schematic": "^1.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ssh2": "^1.17.0",
    "three": "^0.184.0",
    "vec3": "^0.2.0",
    "vite": "^6.2.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/mssql": "^12.3.0",
    "@types/node": "^22.14.0",
    "@types/ssh2": "^1.15.5",
    "autoprefixer": "^10.4.21",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.5"
  }
}
